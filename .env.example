# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_POOLER_URL=your-pooler-connection-string

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Stripe Subscription Price IDs
STRIPE_PRO_PRICE_ID=your-pro-price-id
STRIPE_PREMIUM_PRICE_ID=your-premium-price-id

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email notifications (Resend)
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=noreply@yourdomain.com

# Resend Webhook Secret
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret

# Unsubscribe token signing secret
UNSUBSCRIBE_SECRET=your-random-secret

# Google Calendar Integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cron Jobs Security
CRON_SECRET=your-random-secret

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# IndexNow
INDEXNOW_API_KEY=your-key-here

# ISR Revalidation Secret
REVALIDATE_SECRET=your-random-secret

# Voice Qualification (Vapi + ElevenLabs)
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_ASSISTANT_ID=

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_ID=your-clarity-id

# Admin Access
ADMIN_EMAILS=admin@example.com

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=your-redis-url
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Daily.co
DAILY_API_KEY=your-daily-api-key

# Sentry (optional)
SENTRY_DSN=your-sentry-dsn

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=your-ga-id

# Data Ingestion APIs
COURTLISTENER_API_TOKEN=your-courtlistener-api-token
