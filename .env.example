# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email notifications (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@us-attorneys.com

# Resend Webhook Secret (from Resend dashboard -> Webhooks)
RESEND_WEBHOOK_SECRET=whsec_...

# Unsubscribe token signing secret
UNSUBSCRIBE_SECRET=your-random-unsubscribe-secret

# Google Calendar Integration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cron Jobs Security
CRON_SECRET=your-random-cron-secret

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# IndexNow (instant search engine notification)
INDEXNOW_API_KEY=your-32-char-hex-key

# ISR Revalidation Secret
REVALIDATE_SECRET=your-revalidation-secret

# Voice Qualification (Vapi + ElevenLabs)
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_ASSISTANT_ID=

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_ID=vu7obqjwh9

# Admin Access
ADMIN_EMAILS=admin@example.com,admin2@example.com

# Redis (Upstash) — rate limiting & cache
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Daily.co — video consultations
DAILY_API_KEY=your-daily-api-key

# Sentry — error monitoring (optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Data Ingestion APIs
COURTLISTENER_API_TOKEN=your-courtlistener-api-token
# Get free token: https://www.courtlistener.com/register/ then https://www.courtlistener.com/profile/
