  "regions": ["iad1"],
  "functions": {
    "src/app/**/*.tsx": {
      "maxDuration": 30
    },
    "src/app/api/cron/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/sitemap-attorneys/route.ts": {
      "maxDuration": 60
